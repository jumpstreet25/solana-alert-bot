# ══════════════════════════════════════════════════════════════════════════════
# Solana Alert Bot — environment variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ══════════════════════════════════════════════════════════════════════════════

# ── Polling ────────────────────────────────────────────────────────────────────
# How often to scan all tokens (seconds). 120 = 2 minutes.
POLL_INTERVAL=120

# Minimum time between repeat alerts for the same token (minutes).
# Prevents alert spam when a signal lingers.
ALERT_COOLDOWN_MINUTES=60

# Minimum confluence score to fire an alert (out of 7, default 5).
MIN_SCORE=5

# ── File paths ─────────────────────────────────────────────────────────────────
TOKENS_FILE=tokens.json

# ── Firebase Cloud Messaging ───────────────────────────────────────────────────
# Path to the JSON service-account key downloaded from:
#   Firebase Console → Project Settings → Service Accounts → Generate new private key
FCM_CREDENTIALS_FILE=firebase-credentials.json

# Topic name — your mobile app must subscribe to this topic:
#   FirebaseMessaging.getInstance().subscribeToTopic("solana_alerts")
FCM_TOPIC=solana_alerts

# OR send to a specific device instead of a topic (leave blank to use topic):
FCM_DEVICE_TOKEN=

# ── Telegram (optional) ────────────────────────────────────────────────────────
# 1. Create a bot via @BotFather on Telegram → /newbot → copy the token below.
# 2. Get your chat ID: message @userinfobot on Telegram.
# Leave blank to disable Telegram notifications.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
